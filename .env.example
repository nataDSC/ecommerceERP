# ─────────────────────────────────────────────────
# ecommerceERP — Environment Configuration Template
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — NEVER commit real secrets.

# ── Tavily Market Research API ───────────────────
# Required for live market research calls.
# Get your key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Set to "true" to use mock data instead of calling Tavily.
# Recommended during development and all unit tests.
TAVILY_MOCK=false

# ── Agent Cost-Guard ──────────────────────────────
# Maximum external tool calls allowed per agent cycle.
# Prevents runaway loops. Default: 5
MAX_TOOL_CALLS_PER_CYCLE=5

# ── Observability ─────────────────────────────────
# Directory where reasoning_trace.log will be written.
# Default: ./logs  (created automatically if missing)
LOG_DIR=./logs

# ─────────────────────────────────────────────────
# ecommerceERP — Environment Configuration Template
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — NEVER commit real secrets.

# ── Tavily Market Research API ───────────────────
# Required for live market research calls.
# Get your key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Set to "true" to use mock data instead of calling Tavily.
# Recommended during development and all unit tests.
TAVILY_MOCK=false

# ── Agent Cost-Guard ──────────────────────────────
# Maximum external tool calls allowed per agent cycle.
# Prevents runaway loops. Default: 5
MAX_TOOL_CALLS_PER_CYCLE=5

# ── Observability ─────────────────────────────────
# Directory where reasoning_trace.log will be written.
# Default: ./logs  (created automatically if missing)
LOG_DIR=./logs

# ── FastAPI Service ───────────────────────────────
# API bind address and port
API_HOST=0.0.0.0
API_PORT=8000

# Optional basic auth for API endpoints
# false = disabled (default for local dev)
# true  = enabled (recommended for shared environments)
API_AUTH_ENABLED=false
API_BASIC_AUTH_USER=admin
API_BASIC_AUTH_PASS=change_me

# Persistence backend for API run history and audit trail
# Supported values: sqlite, postgres
API_DB_BACKEND=sqlite

# SQLite path (used when API_DB_BACKEND=sqlite)
API_DB_PATH=.data/api_runs.db

# Postgres DSN (used when API_DB_BACKEND=postgres)
# Example: postgresql://postgres:postgres@localhost:5432/ecommerce_erp
API_POSTGRES_DSN=
